rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /clausecheck_users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Update allowed only if plan unchanged and credits never increase (decrease-only)
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.credits <= resource.data.credits;
      allow delete: if false;
    }
    match /clausecheck_users/{userId}/analyses/{analysisId} {
      allow read, create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if false;
    }
  }
}
